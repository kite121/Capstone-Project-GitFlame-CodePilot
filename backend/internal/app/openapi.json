{
  "openapi": "3.0.3",
  "info": {
    "title": "GitFlame CodePilot Backend",
    "version": "0.1.0",
    "description": "Sprint 1 Go backend contract for GitFlame AI integration."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local backend"
    }
  ],
  "tags": [
    {
      "name": "health",
      "description": "Service health checks"
    },
    {
      "name": "issue workflow",
      "description": "Issue-to-plan and approve/correct/reject flow"
    },
    {
      "name": "recommendations",
      "description": "Repository recommendation analysis flow"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Backend health check",
        "responses": {
          "200": {
            "description": "Backend is available",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/integrations/gitflame/issues/analyze": {
      "post": {
        "tags": ["issue workflow"],
        "summary": "Analyze GitFlame issue and generate implementation plan",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IssueAnalyzeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated plan and comment body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueAnalyzeResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
    "/ai/issues/{id}/plan": {
      "get": {
        "tags": ["issue workflow"],
        "summary": "Return generated issue plan",
        "parameters": [
          {
            "$ref": "#/components/parameters/IssueID"
          }
        ],
        "responses": {
          "200": {
            "description": "Generated issue plan",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssuePlanResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/ai/issues/{id}/approve": {
      "post": {
        "tags": ["issue workflow"],
        "summary": "Approve generated plan and create mock PR payload",
        "parameters": [
          {
            "$ref": "#/components/parameters/IssueID"
          }
        ],
        "responses": {
          "200": {
            "description": "Mock Git workflow response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlanActionResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/ai/issues/{id}/correct": {
      "post": {
        "tags": ["issue workflow"],
        "summary": "Request plan correction and save a new revision",
        "parameters": [
          {
            "$ref": "#/components/parameters/IssueID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlanCorrectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated plan revision",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlanActionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
    "/ai/issues/{id}/reject": {
      "post": {
        "tags": ["issue workflow"],
        "summary": "Reject generated plan",
        "parameters": [
          {
            "$ref": "#/components/parameters/IssueID"
          }
        ],
        "responses": {
          "200": {
            "description": "Rejected plan state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlanActionResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/integrations/gitflame/repositories/{id}/recommendations/analyze": {
      "post": {
        "tags": ["recommendations"],
        "summary": "Analyze repository and save recommendation cards",
        "parameters": [
          {
            "$ref": "#/components/parameters/RepositoryID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecommendationAnalyzeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Saved recommendation report",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecommendationAnalyzeResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
    "/repositories/{id}/recommendations/status": {
      "get": {
        "tags": ["recommendations"],
        "summary": "Return repository recommendation status",
        "parameters": [
          {
            "$ref": "#/components/parameters/RepositoryID"
          }
        ],
        "responses": {
          "200": {
            "description": "Recommendation status counters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecommendationStatusResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/repositories/{id}/recommendations/summary": {
      "get": {
        "tags": ["recommendations"],
        "summary": "Return repository recommendation summary",
        "parameters": [
          {
            "$ref": "#/components/parameters/RepositoryID"
          }
        ],
        "responses": {
          "200": {
            "description": "Recommendation summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecommendationSummaryResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/repositories/{id}/recommendations": {
      "get": {
        "tags": ["recommendations"],
        "summary": "Return repository recommendation cards",
        "parameters": [
          {
            "$ref": "#/components/parameters/RepositoryID"
          }
        ],
        "responses": {
          "200": {
            "description": "Recommendation cards",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecommendationListResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/recommendations/{id}/close": {
      "patch": {
        "tags": ["recommendations"],
        "summary": "Close recommendation card",
        "parameters": [
          {
            "$ref": "#/components/parameters/RecommendationID"
          }
        ],
        "responses": {
          "200": {
            "description": "Closed recommendation card",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecommendationCard"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/recommendations/{id}": {
      "delete": {
        "tags": ["recommendations"],
        "summary": "Delete recommendation card",
        "parameters": [
          {
            "$ref": "#/components/parameters/RecommendationID"
          }
        ],
        "responses": {
          "204": {
            "description": "Recommendation deleted"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "IssueID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "42"
      },
      "RepositoryID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "gitflame/backend"
      },
      "RecommendationID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Malformed request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Requested object was not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "ValidationError": {
        "description": "Request did not satisfy the Sprint 1 contract",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["service", "status"],
        "properties": {
          "service": {
            "type": "string",
            "example": "backend"
          },
          "status": {
            "type": "string",
            "example": "ok"
          }
        }
      },
      "RepositoryMetadata": {
        "type": "object",
        "required": ["id", "default_branch"],
        "properties": {
          "id": {
            "type": "string",
            "example": "gitflame/backend"
          },
          "name": {
            "type": "string",
            "example": "backend"
          },
          "default_branch": {
            "type": "string",
            "example": "main"
          },
          "web_url": {
            "type": "string",
            "example": "https://gitflame.example/gitflame/backend"
          }
        }
      },
      "IssuePayload": {
        "type": "object",
        "required": ["id", "title", "body", "author"],
        "properties": {
          "id": {
            "type": "string",
            "example": "42"
          },
          "title": {
            "type": "string",
            "example": "Add audit logs"
          },
          "body": {
            "type": "string",
            "example": "Need audit logs for AI PRs"
          },
          "author": {
            "type": "string",
            "example": "artur"
          }
        }
      },
      "IssueAnalyzeRequest": {
        "type": "object",
        "required": ["repository", "issue", "yaml_config"],
        "properties": {
          "repository": {
            "$ref": "#/components/schemas/RepositoryMetadata"
          },
          "issue": {
            "$ref": "#/components/schemas/IssuePayload"
          },
          "yaml_config": {
            "type": "string",
            "example": "version: 1\nrepository:\n  target_branch_prefix: ai/\nanalysis:\n  enabled: true\n"
          },
          "repository_context": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["README.md", "internal/app/server.go"]
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "IssueAnalyzeResponse": {
        "type": "object",
        "required": ["session_id", "issue_id", "repository_id", "status", "plan_markdown", "comment_body", "next_actions"],
        "properties": {
          "session_id": {
            "type": "string"
          },
          "issue_id": {
            "type": "string"
          },
          "repository_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["plan_generated"]
          },
          "plan_markdown": {
            "type": "string"
          },
          "comment_body": {
            "type": "string"
          },
          "next_actions": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "example": {
              "approve": "/approve",
              "correct": "/correct",
              "reject": "/reject"
            }
          }
        }
      },
      "IssuePlanResponse": {
        "type": "object",
        "required": ["session_id", "issue_id", "repository_id", "status", "plan_markdown", "comment_body", "revision"],
        "properties": {
          "session_id": {
            "type": "string"
          },
          "issue_id": {
            "type": "string"
          },
          "repository_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "plan_markdown": {
            "type": "string"
          },
          "comment_body": {
            "type": "string"
          },
          "revision": {
            "type": "integer",
            "example": 1
          }
        }
      },
      "PlanCorrectionRequest": {
        "type": "object",
        "required": ["feedback"],
        "properties": {
          "feedback": {
            "type": "string",
            "example": "Add database migration and tests to the plan."
          }
        }
      },
      "GitWorkflowResponse": {
        "type": "object",
        "required": ["branch_name", "pull_request_url", "reviewer", "provider"],
        "properties": {
          "branch_name": {
            "type": "string",
            "example": "ai/42-add-audit-logs"
          },
          "pull_request_url": {
            "type": "string",
            "example": "https://gitflame.local/gitflame/backend/-/merge_requests/mock-42"
          },
          "reviewer": {
            "type": "string",
            "example": "artur"
          },
          "provider": {
            "type": "string",
            "example": "mock"
          }
        }
      },
      "PlanActionResponse": {
        "type": "object",
        "required": ["session_id", "issue_id", "status", "message"],
        "properties": {
          "session_id": {
            "type": "string"
          },
          "issue_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["approved", "correction_requested", "rejected"]
          },
          "message": {
            "type": "string"
          },
          "plan_markdown": {
            "type": "string"
          },
          "git_workflow": {
            "$ref": "#/components/schemas/GitWorkflowResponse"
          }
        }
      },
      "RecommendationAnalyzeRequest": {
        "type": "object",
        "required": ["repository", "yaml_config"],
        "properties": {
          "repository": {
            "$ref": "#/components/schemas/RepositoryMetadata"
          },
          "yaml_config": {
            "type": "string"
          },
          "repository_context": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "RecommendationCard": {
        "type": "object",
        "required": ["id", "severity", "file", "problem", "suggestion", "state"],
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "example": "low"
          },
          "file": {
            "type": "string",
            "example": "README.md"
          },
          "line": {
            "type": "integer",
            "nullable": true
          },
          "problem": {
            "type": "string"
          },
          "suggestion": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "format": "float",
            "nullable": true,
            "minimum": 0,
            "maximum": 1
          },
          "state": {
            "type": "string",
            "enum": ["open", "closed"]
          }
        }
      },
      "RecommendationAnalyzeResponse": {
        "type": "object",
        "required": ["repository_id", "status", "summary", "recommendations"],
        "properties": {
          "repository_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "example": "ready"
          },
          "summary": {
            "type": "string"
          },
          "recommendations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecommendationCard"
            }
          }
        }
      },
      "RecommendationStatusResponse": {
        "type": "object",
        "required": ["repository_id", "status", "total", "open", "closed"],
        "properties": {
          "repository_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "total": {
            "type": "integer"
          },
          "open": {
            "type": "integer"
          },
          "closed": {
            "type": "integer"
          }
        }
      },
      "RecommendationSummaryResponse": {
        "type": "object",
        "required": ["repository_id", "summary"],
        "properties": {
          "repository_id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      },
      "RecommendationListResponse": {
        "type": "object",
        "required": ["repository_id", "recommendations"],
        "properties": {
          "repository_id": {
            "type": "string"
          },
          "recommendations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecommendationCard"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["detail"],
        "properties": {
          "detail": {
            "type": "string"
          }
        }
      }
    }
  }
}
