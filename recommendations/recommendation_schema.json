{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitflame.example/schemas/recommendation-response.schema.json",
  "title": "GitFlame Recommendation Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "recommendations"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 800
    },
    "recommendations": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/recommendation"
      }
    }
  },
  "$defs": {
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "category",
        "file",
        "line",
        "problem",
        "suggestion",
        "confidence"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "category": {
          "type": "string",
          "enum": [
            "code_duplication",
            "security",
            "maintainability",
            "performance",
            "architecture"
          ]
        },
        "file": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "problem": {
          "type": "string",
          "minLength": 1,
          "maxLength": 800
        },
        "suggestion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 800
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
